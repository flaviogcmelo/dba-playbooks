# listener.ora — Gerado pelo Ansible
# Static listener necessário para o RMAN DUPLICATE e Data Guard Broker

LISTENER =
  (DESCRIPTION_LIST =
    (DESCRIPTION =
      (ADDRESS = (PROTOCOL = TCP)(HOST = {{ oracle_hostname }})(PORT = {{ oracle_listener_port }}))
      (ADDRESS = (PROTOCOL = IPC)(KEY = EXTPROC1521))
    )
  )

# Registro estático — necessário para instâncias em NOMOUNT/MOUNT (standby)
SID_LIST_LISTENER =
  (SID_LIST =
    (SID_DESC =
      (GLOBAL_DBNAME = {{ oracle_db_name }})
      (ORACLE_HOME = {{ oracle_home }})
      (SID_NAME = {{ oracle_sid }})
    )
{% if hostvars[inventory_hostname]['dg_role'] == 'PHYSICAL_STANDBY' %}
    (SID_DESC =
      (GLOBAL_DBNAME = {{ oracle_db_name }}STBY)
      (ORACLE_HOME = {{ oracle_home }})
      (SID_NAME = {{ oracle_sid }})
    )
{% endif %}
  )

ADR_BASE_LISTENER = {{ oracle_base }}
